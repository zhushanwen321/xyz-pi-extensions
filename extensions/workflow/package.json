{
  "name": "@zhushanwen/pi-workflow",
  "version": "0.1.8",
  "description": "Multi-agent workflow orchestration for Pi — stateful workflow management with persistence, state machine, and execution tracing.",
  "type": "module",
  "main": "index.ts",
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "keywords": [
    "pi-package",
    "extension",
    "workflow",
    "orchestration",
    "multi-agent"
  ],
  "license": "MIT",
  "files": [
    "src/",
    "index.ts",
    "skills/"
  ],
  "dependencies": {},
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*",
    "@zhushanwen/pi-model-switch": "*",
    "@zhushanwen/pi-structured-output": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-tui": {
      "optional": true
    },
    "@mariozechner/pi-ai": {
      "optional": true
    },
    "@zhushanwen/pi-structured-output": {
      "optional": true
    }
  },
  "scripts": {
    "typecheck": "npx tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "vitest": "^4.1.8"
  }
}
