{
  "name": "@zhushanwen/pi-coding-workflow",
  "version": "0.3.0",
  "description": "5-phase coding workflow orchestration",
  "main": "index.ts",
  "type": "module",
  "files": [
    "index.ts",
    "lib/",
    "scripts/",
    "skills/",
    "agents/",
    "commands/"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.1.0",
    "@mariozechner/pi-tui": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-tui": {
      "optional": true
    },
    "@mariozechner/pi-ai": {
      "optional": true
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/js-yaml": "^4.0.0"
  }
}
