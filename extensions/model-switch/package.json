{
  "name": "@zhushanwen/pi-model-switch",
  "version": "0.2.8",
  "description": "Intelligent model recommendation and switching for Pi coding agent",
  "type": "module",
  "main": "index.ts",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "model",
    "switch",
    "advisor"
  ],
  "license": "MIT",
  "files": [
    "index.ts",
    "src/**/*.ts",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
