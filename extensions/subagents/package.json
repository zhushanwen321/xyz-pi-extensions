{
  "name": "@zhushanwen/pi-subagents",
  "version": "0.1.0",
  "type": "module",
  "main": "index.ts",
  "description": "Spawned-process agent execution runtime for Pi — unified execute entry, isolated state, sync/background modes",
  "keywords": [
    "pi-package",
    "extension",
    "subagent",
    "agent-runtime"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.ts",
    "agents/",
    "src/index.ts",
    "src/types.ts",
    "src/core/",
    "src/runtime/",
    "src/tui/",
    "src/tools/",
    "src/commands/",
    "src/utils/"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "typecheck": "npx tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {},
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@mariozechner/pi-ai": {
      "optional": true
    },
    "@sinclair/typebox": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "vitest": "^4.1.8"
  }
}
