{
  "name": "@zhushanwen/pi-evolve-daily",
  "version": "0.2.1",
  "description": "Daily evolution data collector — runs Python analyzer on first session of the day.",
  "type": "module",
  "license": "MIT",
  "main": "src/index.ts",
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "keywords": [
    "pi-package"
  ],
  "files": [
    "src/",
    "index.ts",
    "skills/",
    "scripts/**/*.py",
    "analyzer/"
  ],
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-tui": {
      "optional": true
    },
    "@mariozechner/pi-ai": {
      "optional": true
    }
  },
  "scripts": {
    "typecheck": "npx tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "vitest": "^4.1.8"
  }
}
