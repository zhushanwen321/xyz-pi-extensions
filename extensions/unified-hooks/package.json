{
  "name": "@zhushanwen/pi-unified-hooks",
  "version": "0.1.1",
  "description": "Unified hooks extension - collect scattered hooks in one place for easy maintenance",
  "main": "index.ts",
  "type": "module",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "typecheck": "npx tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "pi-package",
    "extension",
    "hooks"
  ],
  "license": "MIT",
  "peerDependencies": {
    "typebox": "*",
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "vitest": "^4.1.8"
  },
  "files": [
    "src/",
    "index.ts"
  ]
}
