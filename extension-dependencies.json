{
  "$schema": "./extension-dependencies.schema.json",
  "extensions": [
    {
      "name": "@zhushanwen/pi-subagent-workflow",
      "directory": "extensions/subagent-workflow",
      "dependsOn": [
        {
          "package": "@zhushanwen/pi-structured-output",
          "type": "runtime",
          "reason": "subagent 执行 + workflow 编排两端均需 structured-output 扩展加载以提供 schema 结构化输出 tool（代码层不 import，仅运行时 tool 名引用）"
        },
        {
          "package": "@zhushanwen/pi-pending-notifications",
          "type": "runtime",
          "reason": "T2 通知合并：subagent-workflow 的 subagent-service/lifecycle/error-recovery emit pending:register/pending:unregister 事件，pending-notifications 消费该事件并向用户发送完成通知。缺失时后台操作完成无通知（功能降级，不报错）"
        }
      ]
    },
    {
      "name": "@zhushanwen/pi-statusline",
      "directory": "extensions/statusline",
      "dependsOn": [
        {
          "package": "@zhushanwen/pi-quota-providers",
          "type": "package",
          "reason": "直接 import quota-providers 的 provider/quota 配置解析逻辑"
        }
      ]
    },
    {
      "name": "@zhushanwen/pi-model-switch",
      "directory": "extensions/model-switch",
      "dependsOn": [
        {
          "package": "@zhushanwen/pi-quota-providers",
          "type": "package",
          "reason": "直接 import quota-providers 的 provider 解析逻辑"
        }
      ]
    },
    {
      "name": "@zhushanwen/pi-goal",
      "directory": "extensions/goal",
      "dependsOn": [
        {
          "package": "@zhushanwen/pi-todo",
          "type": "optional",
          "reason": "goal 的 prompt 软建议 AI 使用 todo 工具分解/跟踪任务（见 prompts.ts），无运行时/编译期耦合（不再读 pi.__todoGetList，budget 不接收 todo 进度），缺失时 AI 自行判断任务分解"
        }
      ]
    },
    {
      "name": "@zhushanwen/pi-todo",
      "directory": "extensions/todo",
      "dependsOn": []
    },
    {
      "name": "@zhushanwen/pi-vision",
      "directory": "extensions/vision",
      "dependsOn": []
    },
    {
      "name": "@zhushanwen/pi-coding-workflow",
      "directory": "extensions/coding-workflow",
      "dependsOn": [
        {
          "package": "@zhushanwen/pi-subagent-workflow",
          "type": "runtime",
          "reason": "ReviewGate / TestFixLoopGate 通过 pi.__workflowRun 启动 workflow 脚本；硬依赖，缺失时 gate.run() 直接抛错（无 fallback）"
        },
        {
          "package": "@zhushanwen/pi-goal",
          "type": "optional",
          "reason": "Phase 2/3 通过 __goalInit 启动 goal，缺失时降级跳过"
        }
      ]
    },
    {
      "name": "@zhushanwen/pi-context-engineering",
      "directory": "extensions/context-engineering",
      "dependsOn": []
    },
    {
      "name": "@zhushanwen/pi-evolve-daily",
      "directory": "extensions/evolve-daily",
      "dependsOn": []
    },
    {
      "name": "@zhushanwen/pi-unified-hooks",
      "directory": "extensions/unified-hooks",
      "dependsOn": []
    },
    {
      "name": "@zhushanwen/pi-plan",
      "directory": "extensions/plan",
      "dependsOn": [
        {
          "package": "@zhushanwen/pi-goal",
          "type": "optional",
          "reason": "complete action 通过 __goalInit 启动 goal，缺失时降级通知用户"
        }
      ]
    },
    {
      "name": "@zhushanwen/pi-ask-user",
      "directory": "extensions/ask-user",
      "dependsOn": []
    },
    {
      "name": "@zhushanwen/pi-pending-notifications",
      "directory": "extensions/pending-notifications",
      "dependsOn": []
    }
  ]
}
