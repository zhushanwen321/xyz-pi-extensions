{
  "$schema": "./extension-dependencies.schema.json",
  "extensions": [
    {
      "name": "@zhushanwen/pi-workflow",
      "directory": "extensions/workflow",
      "dependsOn": [
        {
          "package": "@zhushanwen/pi-structured-output",
          "type": "optional",
          "reason": "schema 结构化输出，缺失时降级为纯文本"
        },
        {
          "package": "@zhushanwen/pi-model-switch",
          "type": "optional",
          "reason": "有则按复杂度选模型，无则用默认模型"
        }
      ]
    },
    {
      "name": "@zhushanwen/pi-statusline",
      "directory": "extensions/statusline",
      "dependsOn": [
        {
          "package": "@zhushanwen/pi-quota-providers",
          "type": "package",
          "reason": "直接 import quota-providers 的 provider/quota 配置解析逻辑"
        }
      ]
    },
    {
      "name": "@zhushanwen/pi-model-switch",
      "directory": "extensions/model-switch",
      "dependsOn": [
        {
          "package": "@zhushanwen/pi-quota-providers",
          "type": "package",
          "reason": "直接 import quota-providers 的 provider 解析逻辑"
        }
      ]
    },
    {
      "name": "@zhushanwen/pi-goal",
      "directory": "extensions/goal",
      "dependsOn": []
    },
    {
      "name": "@zhushanwen/pi-todo",
      "directory": "extensions/todo",
      "dependsOn": []
    },
    {
      "name": "@zhushanwen/pi-vision",
      "directory": "extensions/vision",
      "dependsOn": []
    },
    {
      "name": "@zhushanwen/pi-coding-workflow",
      "directory": "extensions/coding-workflow",
      "dependsOn": [
        {
          "package": "@zhushanwen/pi-workflow",
          "type": "optional",
          "reason": "Review-Gate / Test-Fix Loop 通过 pi.__workflowRun 启动 workflow 脚本，缺失时降级为 runSingleAgent"
        }
      ]
    },
    {
      "name": "@zhushanwen/pi-claude-rules-loader",
      "directory": "extensions/claude-rules-loader",
      "dependsOn": []
    },
    {
      "name": "@zhushanwen/pi-context-engineering",
      "directory": "extensions/context-engineering",
      "dependsOn": []
    },
    {
      "name": "@zhushanwen/pi-evolve-daily",
      "directory": "extensions/evolve-daily",
      "dependsOn": []
    },
    {
      "name": "@zhushanwen/pi-unified-hooks",
      "directory": "extensions/unified-hooks",
      "dependsOn": []
    },
    {
      "name": "@zhushanwen/pi-turn-timing",
      "directory": "extensions/turn-timing",
      "dependsOn": []
    },
    {
      "name": "@zhushanwen/pi-plan",
      "directory": "extensions/plan",
      "dependsOn": [
        {
          "package": "@zhushanwen/pi-goal",
          "type": "optional",
          "reason": "complete action 通过 __goalInit 启动 goal，缺失时降级通知用户"
        }
      ]
    }
  ]
}
