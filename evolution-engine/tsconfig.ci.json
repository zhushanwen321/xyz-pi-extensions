{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": false,
    "noImplicitAny": false,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["ES2022"],
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": true,
    "typeRoots": ["../node_modules/@types"],
    "paths": {
      "@mariozechner/pi-coding-agent": ["../types/mariozechner/index"],
      "@mariozechner/pi-tui": ["../types/mariozechner/index"],
      "@mariozechner/pi-ai": ["../types/mariozechner/index"],
      "@earendil-works/pi-coding-agent": ["../types/mariozechner/index"],
      "@earendil-works/pi-tui": ["../types/mariozechner/index"],
      "@earendil-works/pi-ai": ["../types/mariozechner/index"],
      "typebox": ["../types/mariozechner/index"]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
