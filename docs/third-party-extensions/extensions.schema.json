{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xyz-pi-extensions/third-party-extensions-registry",
  "title": "Third-Party Extensions Registry",
  "description": "Schema for docs/third-party-extensions/extensions.yaml",
  "type": "object",
  "required": ["extensions"],
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/extension"
      }
    },
    "deep_analyses": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/deepAnalysis"
      }
    }
  },
  "$defs": {
    "extension": {
      "type": "object",
      "required": ["name", "source", "status"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Extension display name or npm package name"
        },
        "source": {
          "type": "string",
          "enum": ["direct-install", "fork-modified", "self-written"],
          "description": "How this extension was adopted"
        },
        "repo": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "Original repository URL (null for self-written)"
        },
        "stars": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "GitHub stars at time of adoption"
        },
        "installed": {
          "type": ["string", "null"],
          "format": "date",
          "description": "Installation date (YYYY-MM-DD)"
        },
        "version": {
          "type": ["string", "null"],
          "description": "Installed version"
        },
        "license": {
          "type": ["string", "null"],
          "description": "SPDX license identifier"
        },
        "status": {
          "type": "string",
          "enum": ["active", "evaluating", "removed", "replaced"],
          "description": "Current status of this extension"
        },
        "npm_package": {
          "type": ["string", "null"],
          "description": "npm package name for installation"
        },
        "replaces": {
          "type": ["string", "null"],
          "description": "Name of the extension this one replaces"
        },
        "replaced_by": {
          "type": ["string", "null"],
          "description": "Name of the extension that replaced this one"
        },
        "inspired_by": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Projects whose ideas influenced this extension (self-written only)"
        },
        "conflicts": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Extensions that conflict with this one"
        },
        "analysis": {
          "type": ["string", "null"],
          "description": "Relative path to the analysis.md document"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Functional domain tags"
        },
        "notes": {
          "type": "string",
          "description": "Brief one-line description"
        }
      }
    },
    "deepAnalysis": {
      "type": "object",
      "required": ["file", "topics", "summary"],
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string",
          "description": "Markdown file name"
        },
        "topics": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Projects/extensions covered"
        },
        "summary": {
          "type": "string",
          "description": "Brief description of the analysis"
        }
      }
    }
  }
}
