#!/bin/bash
# pre-commit — 类型检查 + ESLint 品味检查 + pi manifest 检查 + scripts 校验
#
# 跳过方式：SKIP_LINT=1 git commit -m "..."
set -euo pipefail

if [[ "${SKIP_LINT:-}" == "1" ]]; then
  echo "[pre-commit] SKIP_LINT=1, 跳过检查"
  exit 0
fi

# rebase 中跳过 hook，完成后手动跑一次全量验证
if GIT_DIR=$(git rev-parse --git-dir 2>/dev/null) && \
   [ -d "$GIT_DIR/rebase-merge" ]; then
  echo "[pre-commit] rebase 进行中，跳过 hook"
  exit 0
fi

C_RED='\033[0;31m'
C_GREEN='\033[0;32m'
C_YELLOW='\033[0;33m'
C_RESET='\033[0m'

# ── 0. pi manifest 检查 ──────────────────────────────────
echo "--- pi manifest 检查 ---"
HAS_ERROR=0
for pkg_json in extensions/*/package.json; do
  [ -f "$pkg_json" ] || continue
  dir=$(dirname "$pkg_json")
  name=$(basename "$dir")

  # 跳过 private 包
  is_private=$(python3 -c "import json; print(json.load(open('$pkg_json')).get('private', False))" 2>/dev/null)
  if [[ "$is_private" == "True" ]]; then
    continue
  fi

  # 检查 pi.extensions 字段
  has_pi_ext=$(python3 -c "
import json
import os
d=json.load(open('$pkg_json'))
pi=d.get('pi',{})
exts=pi.get('extensions',[])
if exts:
    # 验证入口文件存在
    for e in exts:
        p=os.path.join('$dir', e.lstrip('./'))
        if not os.path.isfile(p):
            print(f'MISSING_ENTRY:{e}')
            exit(0)
    print('OK')
else:
    print('NO_PI_EXTENSIONS')
" 2>/dev/null)

  if [[ "$has_pi_ext" == "OK" ]]; then
    echo -e "  ${C_GREEN}[ OK ]${C_RESET} $name: pi.extensions 已声明"
  elif [[ "$has_pi_ext" == NO_PI_EXTENSIONS* ]]; then
    echo -e "  ${C_RED}[FAIL]${C_RESET} $name: 缺少 pi.extensions 字段"
    echo -e "         ${C_YELLOW}修复：在 package.json 中添加 \"pi\": { \"extensions\": [\"./src/index.ts\"] }${C_RESET}"
    HAS_ERROR=1
  elif [[ "$has_pi_ext" == MISSING_ENTRY* ]]; then
    entry=${has_pi_ext#MISSING_ENTRY:}
    echo -e "  ${C_RED}[FAIL]${C_RESET} $name: pi.extensions 声明的入口 $entry 不存在"
    HAS_ERROR=1
  fi

  # 检查 type: module
  has_type_module=$(python3 -c "import json; print(json.load(open('$pkg_json')).get('type') == 'module')" 2>/dev/null)
  if [[ "$has_type_module" != "True" ]]; then
    echo -e "  ${C_RED}[FAIL]${C_RESET} $name: 缺少 \"type\": \"module\""
    HAS_ERROR=1
  fi

  # 检查 pi-package keyword
  has_kw=$(python3 -c "import json; print('pi-package' in json.load(open('$pkg_json')).get('keywords',[]))" 2>/dev/null)
  if [[ "$has_kw" != "True" ]]; then
    echo -e "  ${C_RED}[FAIL]${C_RESET} $name: keywords 缺少 \"pi-package\""
    HAS_ERROR=1
  fi
done

if [[ $HAS_ERROR -eq 1 ]]; then
  echo ""
  echo -e "${C_RED}[FAIL]${C_RESET} pi manifest 检查失败"
  echo -e "${C_YELLOW}无论是否本次修改导致，都需要修复，不得跳过${C_RESET}"
  exit 1
fi
echo -e "${C_GREEN}[ OK ]${C_RESET} pi manifest 检查通过"

# ── 0b. package.json 深度检查（peerDeps / files / 包名）──
STAGED_PKG=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(extensions|shared)/.*/package.json$' || true)
if [[ -n "$STAGED_PKG" ]]; then
  echo "--- package.json 深度检查 ---"
  while IFS= read -r pkg_json; do
    dir=$(dirname "$pkg_json")
    name=$(basename "$dir")
    [[ "$name" == "taste-lint" ]] && continue
    is_private=$(python3 -c "import json; print(json.load(open('$pkg_json')).get('private', False))" 2>/dev/null)
    [[ "$is_private" == "True" ]] && continue

    # 包名格式
    pkg_name=$(python3 -c "import json; print(json.load(open('$pkg_json')).get('name', ''))" 2>/dev/null)
    if [[ ! "$pkg_name" =~ ^@zhushanwen/pi- ]]; then
      echo -e "  ${C_RED}[FAIL]${C_RESET} $name: 包名 '$pkg_name' 不符合 @zhushanwen/pi-* 格式"
      HAS_ERROR=1
    fi

    # peerDependencies 含 @mariozechner/pi-coding-agent
    has_core_dep=$(python3 -c "
import json
d=json.load(open('$pkg_json'))
peers=d.get('peerDependencies',{})
print('OK' if '@mariozechner/pi-coding-agent' in peers else 'MISSING')
" 2>/dev/null)
    if [[ "$has_core_dep" == "MISSING" ]]; then
      echo -e "  ${C_RED}[FAIL]${C_RESET} $name: peerDependencies 缺少 @mariozechner/pi-coding-agent"
      HAS_ERROR=1
    fi

    # files 包含入口 .ts
    has_files_entry=$(python3 -c "
import json, glob, os
d=json.load(open('$pkg_json'))
files=d.get('files',[])
pi_exts=d.get('pi',{}).get('extensions',[])
if not pi_exts:
    print('SKIP')
    exit(0)
for ext in pi_exts:
    entry=ext.lstrip('./')
    matched=any(entry.startswith(f.rstrip('/')) if f.endswith('/') else entry in f for f in files)
    if not matched:
        print(f'MISSING:{entry}')
        exit(0)
print('OK')
" 2>/dev/null)
    if [[ "$has_files_entry" == MISSING* ]]; then
      entry=${has_files_entry#MISSING:}
      echo -e "  ${C_RED}[FAIL]${C_RESET} $name: files 未包含入口 ${entry}，npm publish 后会丢失"
      HAS_ERROR=1
    fi

    echo -e "  ${C_GREEN}[ OK ]${C_RESET} $name: 深度检查通过"
  done <<< "$STAGED_PKG"
fi

if [[ $HAS_ERROR -eq 1 ]]; then
  echo ""
  echo -e "${C_RED}[FAIL]${C_RESET} package.json 深度检查失败"
  echo -e "${C_YELLOW}无论是否本次修改导致，都需要修复，不得跳过${C_RESET}"
  exit 1
fi

# ── 0c. scripts 校验（按需触发）─────────────────────
STAGED_YAML=$(git diff --cached --name-only --diff-filter=ACM | grep 'docs/third-party-extensions/extensions.yaml$' || true)
STAGED_SKILLS=$(git diff --cached --name-only --diff-filter=ACM | grep 'SKILL\.md$' || true)

if [[ -n "$STAGED_YAML" ]]; then
  echo "--- validate-extensions-yaml ---"
  if ! python3 scripts/validate-extensions-yaml.py 2>&1; then
    echo -e "${C_RED}[FAIL]${C_RESET} extensions.yaml 校验失败"
    echo -e "${C_YELLOW}修复后重新提交${C_RESET}"
    exit 1
  fi
  echo -e "${C_GREEN}[ OK ]${C_RESET} extensions.yaml 校验通过"
fi

if [[ -n "$STAGED_SKILLS" ]]; then
  echo "--- validate-skill-yaml ---"
  SKILL_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep 'SKILL\.md$')
  if ! python3 scripts/validate-skill-yaml.py $SKILL_FILES 2>&1; then
    echo -e "${C_RED}[FAIL]${C_RESET} SKILL.md YAML frontmatter 校验失败"
    echo -e "${C_YELLOW}修复后重新提交，或用 python3 scripts/validate-skill-yaml.py --fix <files> 自动修复${C_RESET}"
    exit 1
  fi
  echo -e "${C_GREEN}[ OK ]${C_RESET} SKILL.md YAML frontmatter 校验通过"
fi

# ── 1. tsc 类型检查 ──────────────────────────────────────
echo "--- tsc --noEmit ---"
if ! npx tsc --noEmit 2>&1; then
  echo -e "${C_RED}[FAIL]${C_RESET} TypeScript 类型检查失败"
  echo -e "${C_YELLOW}无论是否本次修改导致，都需要修复，不得跳过${C_RESET}"
  exit 1
fi
echo -e "${C_GREEN}[ OK ]${C_RESET} tsc 通过"

# ── 2. ESLint 品味检查（仅检查 staged 的 .ts 文件）──────
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.ts$' | grep -v '\.d\.ts$' || true)

if [[ -z "$STAGED" ]]; then
  echo "[pre-commit] 无 .ts 文件变更，跳过 eslint"
  exit 0
fi

echo "--- eslint ---"
# 将 staged 文件列表传给 eslint
if ! npx eslint $STAGED 2>&1; then
  echo -e "${C_RED}[FAIL]${C_RESET} ESLint 检查失败"
  echo -e "${C_YELLOW}无论是否本次修改导致，都需要修复，不得跳过${C_RESET}"
  echo "修复：npm run lint:fix 或 SKIP_LINT=1 git commit 跳过"
  exit 1
fi
echo -e "${C_GREEN}[ OK ]${C_RESET} eslint 通过"

# ── 3. 单元测试（按需触发）──────────────────────────────
# 检测 staged .ts 文件涉及的包，如果该包有 __tests__/ 则跑 vitest
TEST_PKGS=()
for f in $(git diff --cached --name-only --diff-filter=ACM | grep '\.ts$' | grep -v __tests__ | grep -v vitest.config); do
  # 提取包路径: extensions/statusline/src/foo.ts → extensions/statusline
  pkg_dir=$(echo "$f" | grep -oE '^(extensions|shared)/[^/]+' || true)
  if [[ -n "$pkg_dir" && -d "$pkg_dir/src/__tests__" ]] && ! echo "${TEST_PKGS[@]+${TEST_PKGS[@]}}" | grep -q "$pkg_dir"; then
    TEST_PKGS+=("$pkg_dir")
  fi
done

if [[ ${#TEST_PKGS[@]:-} -gt 0 ]]; then
  echo "--- vitest ---"
  for pkg in "${TEST_PKGS[@]}"; do
    pkg_name=$(python3 -c "import json; print(json.load(open('$pkg/package.json')).get('name', '$pkg'))" 2>/dev/null || echo "$pkg")
    echo "  测试 $pkg_name ..."
    if ! (cd "$pkg" && npx vitest run) 2>&1; then
      echo -e "${C_RED}[FAIL]${C_RESET} $pkg_name 测试失败"
      echo -e "${C_YELLOW}无论是否本次修改导致，都需要修复，不得跳过${C_RESET}"
      exit 1
    fi
  done
  echo -e "${C_GREEN}[ OK ]${C_RESET} vitest 通过"
fi
